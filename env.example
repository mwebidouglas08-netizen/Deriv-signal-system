# ─────────────────────────────────────────────────────────────────────────────
# Deriv AI Signal System — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# For LOCAL development:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. Run:             python main.py
#
# For RAILWAY deployment:
#   Paste each variable into Railway → your project → Variables tab
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Your Deriv API token (Read + Trading information scopes)
# Get it at: app.deriv.com → Settings → API token
DERIV_API_TOKEN=your_deriv_api_token_here

# ── TELEGRAM (recommended) ────────────────────────────────────────────────────

# Create a bot via @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID — message @userinfobot to find it
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── SYMBOLS (optional — defaults shown) ──────────────────────────────────────
# Comma-separated Deriv symbol codes. Remove any you don't want.
SYMBOLS=R_75,R_100,1HZ100V,BOOM1000,CRASH1000

# ── SIGNAL SETTINGS (optional) ───────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.68   # 0.55–0.90 (higher = fewer, stronger signals)
COOLDOWN_SECONDS=180         # Seconds between signals per symbol
TIMEFRAME=1m                 # 1m or 5m

# ── RISK MANAGEMENT (optional) ───────────────────────────────────────────────
RISK_PCT=1.0                 # % of account balance to risk per trade
RR_RATIO=2.0                 # Minimum reward:risk ratio (1:X)
ATR_SL_MULT=1.5              # Stop-loss = ATR × this multiplier

# ── ADVANCED (optional) ───────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
MODEL_SAVE_PATH=/tmp/model.pkl
MODEL_SAVE_INTERVAL=300      # Save model every N seconds
